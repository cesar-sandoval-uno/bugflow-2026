{
  "name": "web",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "web/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "options": {
        "outputPath": "dist/web",
        "index": "web/src/index.html",
        "main": "web/src/main.ts",
        "polyfills": [],
        "tsConfig": "web/tsconfig.app.json",
        "assets": ["web/src/favicon.ico", "web/src/assets"],
        "styles": ["web/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "web/src/environments/environment.ts",
              "with": "web/src/environments/environment.prod.ts"
            }
          ]
        },
        "staging": {
          "fileReplacements": [
            {
              "replace": "web/src/environments/environment.ts",
              "with": "web/src/environments/environment.staging.ts"
            }
          ]
        }
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "web:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "buildTarget": "web:build",
        "port": 4200
      }
    }
  }
}
